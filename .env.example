# Required: OpenAI API key for embeddings and LLM calls
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: OpenRouter API key (fallback for LLM calls)
OPENROUTER_API_KEY=

# Optional: Override workspace root (defaults to ../.. relative to memory/ dir)
# CONSTELLATION_WORKSPACE=/path/to/your/workspace

# Optional: Ollama model for cortex deep-linking (defaults to qwen3:8b)
# OLLAMA_MODEL=qwen3:8b
